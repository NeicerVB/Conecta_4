   "source": [
    "import tkinter as tk\n",
    "\n",
    "root = tk.Tk()\n",
    "root.title(\"6x7 Grid\")\n",
    "\n",
    "# Create 6x7 grid of buttons\n",
    "for row in range(6):\n",
    "    for col in range(7):\n",
    "        button = tk.Button(root, width=4, height=2)\n",
    "        button.grid(row=row, column=col, padx=2, pady=2)\n",
    "\n",
    "root.mainloop()"
   ]
  }
 ],
